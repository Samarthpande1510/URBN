[Unit]
Description=URBN Backend (FastAPI/uvicorn)
After=network.target postgresql.service

[Service]
Type=simple
User=samarth
WorkingDirectory=/home/samarth/URBN/backend
ExecStart=/home/samarth/URBN/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
